# chat-service configuration (copy to .env)

# Shared infra — same Postgres + Redis as the monolith
POSTGRES_URI=postgresql://spaik_user:spaik_pass@localhost:5433/spaik_db
REDIS_URI=redis://:redis_pass@localhost:6379

# MUST match the monolith so monolith-issued access tokens validate here
JWT_SECRET=change_me_min_32_chars

# Service
CHAT_SERVICE_PORT=4001
GRAPHQL_PREFIX=/graphql
NODE_ENV=development
ALLOWED_ORIGIN=http://localhost:3000
