# stream-service configuration (copy to .env)

# Shared infra (same DB as the monolith)
POSTGRES_URI=postgresql://spaik_user:spaik_pass@localhost:5433/spaik_db

# MUST match the monolith to validate access tokens
JWT_SECRET=change_me_min_32_chars

# Web session validation (MUST match the monolith)
REDIS_URI=redis://:redis_pass@localhost:6379
SESSION_NAME=spaik-session
SESSION_SECRET=change_me_session_secret_min_32_chars
SESSION_FOLDER=sessions:

# LiveKit (self-hosted) — same server as the monolith
LIVEKIT_API_URL=ws://localhost:7880
LIVEKIT_API_KEY=spaik_dev_key
LIVEKIT_API_SECRET=spaik_dev_secret_min_32_chars_long

# Service
STREAM_SERVICE_PORT=4004
GRAPHQL_PREFIX=/graphql
NODE_ENV=development
ALLOWED_ORIGIN=http://localhost:3000
