# Your machine's LAN IP — so a real device / emulator can reach the local
# backend (gateway :4002, monolith :4000, media :9000, LiveKit :7880).
# Find it with `ipconfig` (Wi-Fi/Ethernet IPv4 address), then copy this file
# to .env and set the value. Used by app.config.js to build the extra.* URLs.
EXPO_PUBLIC_HOST=192.168.x.x
